{
  "name": "booking-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor native wrapper for the Booking web app",
  "scripts": {
    "web:copy": "node scripts/copy-web-assets.mjs",
    "cap:sync": "npm run web:copy && npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npm run cap:sync && npx cap run ios",
    "cap:run:android": "npm run cap:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/local-notifications": "^7.0.6",
    "@capacitor/network": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "typescript": "^5.8.3"
  }
}
